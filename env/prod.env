#tell Django which settings to use
#whether it's Django/Celery/CeleryBeat/GUnicorn/runserver, they all use Django
#hence, all of them will raise error if file does not exist, or if this variable is missing from environment
#this is a lot better than setting os.environ.setdefault() at files or using --settings at commands
#no spaces between equal signs
#for env in AWS ECS, spaces and quotation marks are included in env var value
#but command in container complains that env is not set when using spaces, e.g. SOME_ENV = SOME_VAR
DJANGO_SETTINGS_MODULE=voicewake.settings.prod

LOCKDOWN_ENABLED=0
LOCKDOWN_PASSWORD=

SECRET_KEY=django-insecure-hdgs8@4nxkx0du^2n-gdss(!eo6i0kj6vk=gx1mddc@g=6h_^1
MAINTENANCE_MODE=0
VERSION=1.0.0

IS_EC2=1

DB_HOST=voicewake-db-staging-1.cpe8caye8jdh.us-east-1.rds.amazonaws.com
DB_NAME=voicewake_staging
DB_USER=postgres
DB_PASSWORD=dsi8TOEDlevb1MJDaeLj
DB_PORT=5432

REDIS_ENDPOINT=voicewake-redis-cluster-1.ihvaze.ng.0001.use1.cache.amazonaws.com:6379

EMAIL_HOST_USER=noreply@voicewake.com
EMAIL_HOST_PASSWORD=rwlkrooftnfaxmno
EMAIL_PORT=465

#S3
#credentials can be omitted in EC2 that has IAM role set up
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=d3fpcqa3tewpp.cloudfront.net
AWS_S3_STATIC_BUCKET_NAME=voicewake-static-bucket
AWS_S3_MEDIA_BUCKET_NAME=voicewake-media-bucket
AWS_S3_UGC_UNPROCESSED_BUCKET_NAME=voicewake-ugc-unprocessed-bucket

#Lambda
