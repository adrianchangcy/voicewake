AWS_LAMBDA_SECRET_ACCESS_KEY=
AWS_LAMBDA_REGION_NAME=us-east-1
AWS_LAMBDA_NORMALISE_FUNCTION_NAME=normalise_audio_clips

#custom AWS values
#3.81mb
